// ---------- Tool 1: Policy-to-Control Mapping ----------

model PolicyMapping {
  id           String            @id @default(cuid())
  userId       String?
  companyId    String?
  frameworks   PolicyFramework[]
  policyDomain PolicyDomain?
  policyText   String?           @db.Text
  industry     String?
  companySize  String?
  aiResponse   String?           @db.Text
  tokensUsed   Int               @default(0)
  costUsd      Float             @default(0)
  createdAt    DateTime          @default(now())

  company CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("policy_mappings")
}

// ---------- Tool 2: Incident Materiality Assessment ----------

model IncidentAssessment {
  id                String            @id @default(cuid())
  userId            String
  companyId         String?
  incidentType      IncidentType
  description       String            @db.Text
  recordsAffected   Int?
  dataTypesInvolved String[]
  discoveryDate     DateTime?
  containmentDate   DateTime?
  industry          String?
  isPublicCompany   Boolean           @default(false)
  materialityLevel  MaterialityLevel?
  aiResponse        String?           @db.Text
  tokensUsed        Int               @default(0)
  costUsd           Float             @default(0)
  createdAt         DateTime          @default(now())

  company CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("incident_assessments")
}

// ---------- Tool 3: Board Report Generator ----------

model BoardReport {
  id          String          @id @default(cuid())
  userId      String
  companyId   String?
  reportType  BoardReportType
  periodStart DateTime
  periodEnd   DateTime
  focusAreas  String[]
  audience    String?
  aiResponse  String?         @db.Text
  tokensUsed  Int             @default(0)
  costUsd     Float           @default(0)
  createdAt   DateTime        @default(now())

  company CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("board_reports")
}

// ---------- Tool 4: AI System Inventory ----------

model AISystem {
  id                 String       @id @default(cuid())
  companyId          String
  name               String
  description        String       @db.Text
  purpose            String?      @db.Text
  modelType          String?
  modelProvider      String?
  dataClassification String?
  riskLevel          AIRiskLevel?
  department         String?
  owner              String?
  status             String       @default("ACTIVE")
  deploymentDate     DateTime?
  lastReviewDate     DateTime?
  dataSources        String[]
  outputTypes        String[]
  affectedPersons    String[]
  humanOversight     String?      @db.Text
  aiAnalysis         Json?
  tokensUsed         Int          @default(0)
  costUsd            Float        @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([riskLevel])
  @@index([status])
  @@map("ai_systems")
}

// ---------- Tool 5: Enterprise Risk Register ----------

model Risk {
  id            String       @id @default(cuid())
  companyId     String
  title         String
  description   String       @db.Text
  category      RiskCategory
  likelihood    Int          @default(3)
  impact        Int          @default(3)
  inherentScore Float?
  owner         String?
  status        String       @default("OPEN")
  mitigations   String[]
  controls      String[]
  residualScore Float?
  targetDate    DateTime?
  reviewDate    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company     CompanyProfile   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assessments RiskAssessment[]

  @@index([companyId])
  @@index([category])
  @@index([status])
  @@map("risks")
}

model RiskAssessment {
  id         String   @id @default(cuid())
  riskId     String
  analysis   Json
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  risk Risk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@map("risk_assessments")
}

// ---------- Tool 6a: DSAR Response Generator ----------

model DSARRequest {
  id              String   @id @default(cuid())
